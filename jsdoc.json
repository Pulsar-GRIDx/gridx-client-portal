{
  "source": {
    "include": ["src"],
    "exclude": ["node_modules"],
    "includePattern": ".js(x)?$",
    "excludePattern": "(node_modules|docs)"
  },
  "plugins": ["plugins/markdown"],
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true,
    "default": {
      "staticFiles": {
        "include": ["./static"]
      }
    }
  },
  "opts": {
    "destination": "./docs/",
    "template": "node_modules/docdash",
    "recurse": true
  }
}
